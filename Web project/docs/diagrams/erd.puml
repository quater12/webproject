@startuml
entity User {
  * id : bigint <<PK>>
  --
  * email : varchar(255) <<UNIQUE>>
  * password_hash : varchar(255)
  * first_name : varchar(100)
  * last_name : varchar(100)
  * role : varchar(20) CHECK(role in ['customer','admin'])
  * is_active : boolean
  * created_at : timestamp
  * updated_at : timestamp
}

entity Platform {
  * id : bigint <<PK>>
  --
  * name : varchar(100) <<UNIQUE>>
  * manufacturer : varchar(120)
  * release_year : integer
  * generation : varchar(50)
  * is_portable : boolean
  * created_at : timestamp
}

entity Genre {
  * id : bigint <<PK>>
  --
  * name : varchar(60) <<UNIQUE>>
  description : text
  * created_at : timestamp
}

entity Game {
  * id : bigint <<PK>>
  --
  * title : varchar(200)
  * sku : varchar(40) <<UNIQUE>>
  * platform_id : bigint <<FK>>
  * description : text
  * price : decimal(10,2)
  * stock : integer CHECK(stock >= 0)
  * condition : varchar(20) CHECK(condition in ['new','used','refurbished'])
  * is_active : boolean
  * created_at : timestamp
  * updated_at : timestamp
}

entity GameGenre {
  * id : bigint <<PK>>
  --
  * game_id : bigint <<FK>>
  * genre_id : bigint <<FK>>
}

entity Cart {
  * id : bigint <<PK>>
  --
  * user_id : bigint <<FK, UNIQUE>>
  * created_at : timestamp
  * updated_at : timestamp
}

entity CartItem {
  * id : bigint <<PK>>
  --
  * cart_id : bigint <<FK>>
  * game_id : bigint <<FK>>
  * quantity : integer CHECK(quantity > 0)
  * added_at : timestamp
}

entity Order {
  * id : bigint <<PK>>
  --
  * user_id : bigint <<FK>>
  * status : varchar(20) CHECK(status in ['pending','paid','shipped','delivered','cancelled'])
  * total_amount : decimal(10,2)
  * shipping_address : varchar(255)
  * created_at : timestamp
  * updated_at : timestamp
}

entity OrderItem {
  * id : bigint <<PK>>
  --
  * order_id : bigint <<FK>>
  * game_id : bigint <<FK>>
  * unit_price : decimal(10,2)
  * quantity : integer CHECK(quantity > 0)
}

User ||--o{ Order
User ||--|| Cart
Platform ||--o{ Game
Game ||--o{ CartItem
Cart ||--o{ CartItem
Order ||--o{ OrderItem
Game ||--o{ OrderItem
Game ||--o{ GameGenre
Genre ||--o{ GameGenre
@enduml
