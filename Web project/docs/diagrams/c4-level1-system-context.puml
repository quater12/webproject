@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Context.puml

Person(customer, "Customer", "Buys retro games")
Person(admin, "Admin", "Maintains catalog and orders")
System(retrovault, "RetroVault System", "Web platform for retro game marketplace")
System_Ext(email, "Email Service", "Sends order notifications")

Rel(customer, retrovault, "Browse, order, track", "HTTPS")
Rel(admin, retrovault, "Manage products/orders", "HTTPS")
Rel(retrovault, email, "Send confirmation and updates", "SMTP/API")
@enduml
