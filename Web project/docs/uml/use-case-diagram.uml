@startuml
left to right direction
actor Guest
actor Customer
actor Admin

rectangle RetroVault {
  usecase "Browse catalog" as UC1
  usecase "Search and filter games" as UC2
  usecase "Register/Login" as UC3
  usecase "Manage cart" as UC4
  usecase "Place order" as UC5
  usecase "Track order status" as UC6
  usecase "Manage games" as UC7
  usecase "Manage platforms/genres" as UC8
}

Guest --> UC1
Guest --> UC2
Guest --> UC3
Customer --> UC1
Customer --> UC2
Customer --> UC4
Customer --> UC5
Customer --> UC6
Admin --> UC7
Admin --> UC8
Admin --> UC6

UC5 .> UC4 : <<include>>
UC5 .> UC3 : <<include>>
@enduml
